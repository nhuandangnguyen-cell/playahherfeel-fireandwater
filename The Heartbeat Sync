}

/* ─── RESET ─── */
function resetGame() {
  clearInterval(gameInterval);
  cancelAnimationFrame(hbAnim);
  document.getElementById('mist-container').innerHTML = '';
  goTo(1);
}

/* ─── PREVENT DEFAULT TOUCHSTART ON GAME BUTTONS ─── */
document.querySelectorAll('.tap-btn').forEach(btn => {
  btn.addEventListener('touchstart', e => e.preventDefault(), { passive: false });
});
</script>
