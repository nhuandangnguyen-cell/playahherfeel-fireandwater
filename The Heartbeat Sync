<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Intimacy Flow — PlayAh Her Feel</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Outfit:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --fire-1: #ff4500;
    --fire-2: #ff8c00;
    --fire-3: #ffd700;
    --water-1: #003d6b;
    --water-2: #0077b6;
    --water-3: #90e0ef;
    --water-4: #caf0f8;
    --deep: #060912;
    --mid: #0d1524;
    --surface: rgba(255,255,255,0.05);
    --gold: #c9a84c;
    --white: #f5f0ea;
  }

  html, body {
    width: 100%; min-height: 100vh;
    background: var(--deep);
    font-family: 'Outfit', sans-serif;
    color: var(--white);
    overflow-x: hidden;
  }

  /* ─── CANVAS BACKGROUND ─── */
  #bg-canvas {
    position: fixed; inset: 0; z-index: 0;
    pointer-events: none;
  }

  /* ─── SCREENS ─── */
  .screen {
    position: relative; z-index: 1;
    min-height: 100vh;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    padding: 2rem;
    text-align: center;
    display: none;
  }
  .screen.active { display: flex; }

  /* ─── LOGO ─── */
  .logo {
    position: fixed; top: 1.5rem; left: 50%;
    transform: translateX(-50%);
    z-index: 100;
    font-family: 'Cormorant Garamond', serif;
    font-size: 0.75rem;
    font-weight: 300;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.5);
  }

  /* ─── TYPOGRAPHY ─── */
  .eyebrow {
    font-size: 0.7rem;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: var(--fire-2);
    margin-bottom: 1rem;
    font-weight: 400;
  }
  h1 {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2.8rem, 7vw, 5rem);
    font-weight: 300;
    line-height: 1.1;
    margin-bottom: 0.3em;
  }
  h1 em { font-style: italic; color: var(--water-3); }
  h1 .fire-word { color: var(--fire-2); }
  h2 {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    font-weight: 300;
    line-height: 1.2;
    margin-bottom: 0.5em;
  }
  .subtitle {
    font-size: clamp(0.9rem, 2vw, 1rem);
    font-weight: 300;
    color: rgba(255,255,255,0.65);
    max-width: 520px;
    line-height: 1.8;
    margin-bottom: 2rem;
  }

  /* ─── DIVIDER ─── */
  .divider {
    width: 60px; height: 1px;
    background: linear-gradient(90deg, var(--fire-1), var(--water-2));
    margin: 1.5rem auto;
  }

  /* ─── BUTTONS ─── */
  .btn-primary {
    display: inline-flex; align-items: center; gap: 0.6rem;
    padding: 1rem 2.5rem;
    background: linear-gradient(135deg, var(--fire-1), var(--fire-2));
    border: none; border-radius: 100px;
    color: #fff; font-family: 'Outfit', sans-serif;
    font-size: 0.9rem; font-weight: 500;
    letter-spacing: 0.06em; cursor: pointer;
    transition: transform 0.2s, box-shadow 0.2s;
    box-shadow: 0 0 30px rgba(255,69,0,0.35);
    text-transform: uppercase;
  }
  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 0 50px rgba(255,69,0,0.55);
  }
  .btn-secondary {
    display: inline-flex; align-items: center; gap: 0.5rem;
    padding: 0.8rem 2rem;
    background: transparent;
    border: 1px solid rgba(255,255,255,0.25); border-radius: 100px;
    color: rgba(255,255,255,0.7); font-family: 'Outfit', sans-serif;
    font-size: 0.85rem; font-weight: 400;
    letter-spacing: 0.05em; cursor: pointer;
    transition: border-color 0.2s, color 0.2s;
  }
  .btn-secondary:hover {
    border-color: rgba(255,255,255,0.5);
    color: #fff;
  }

  /* ─── SCREEN 1: LANDING ─── */
  .hero-badge {
    display: inline-block;
    padding: 0.4rem 1.2rem;
    border: 1px solid rgba(201,168,76,0.4);
    border-radius: 100px;
    font-size: 0.7rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 2rem;
  }
  .element-icons {
    display: flex; align-items: center; gap: 1.5rem;
    justify-content: center;
    margin-bottom: 2rem;
  }
  .element-icon {
    width: 64px; height: 64px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 1.8rem;
  }
  .fire-icon {
    background: radial-gradient(circle at 50% 70%, rgba(255,69,0,0.3), transparent);
    border: 1px solid rgba(255,140,0,0.3);
    animation: flicker 2s infinite alternate;
  }
  .water-icon {
    background: radial-gradient(circle at 50% 30%, rgba(0,119,182,0.3), transparent);
    border: 1px solid rgba(144,224,239,0.3);
    animation: ripple 3s infinite;
  }
  .plus-sign {
    font-size: 1.4rem;
    color: rgba(255,255,255,0.3);
    font-weight: 200;
  }
  @keyframes flicker {
    0% { box-shadow: 0 0 15px rgba(255,69,0,0.3); }
    100% { box-shadow: 0 0 35px rgba(255,140,0,0.6); }
  }
  @keyframes ripple {
    0%, 100% { box-shadow: 0 0 0 0 rgba(0,119,182,0.4); }
    50% { box-shadow: 0 0 0 12px rgba(0,119,182,0); }
  }

  /* ─── SCREEN 2: INSTRUCTIONS ─── */
  .steps-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1.2rem;
    max-width: 700px;
    margin: 1.5rem auto 2rem;
    text-align: left;
  }
  .step-card {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 16px;
    padding: 1.4rem;
    position: relative;
    overflow: hidden;
  }
  .step-card::before {
    content: '';
    position: absolute; inset: 0;
    background: linear-gradient(135deg, rgba(255,69,0,0.05), transparent 60%);
    pointer-events: none;
  }
  .step-num {
    font-family: 'Cormorant Garamond', serif;
    font-size: 2.5rem;
    font-weight: 300;
    line-height: 1;
    color: rgba(255,140,0,0.3);
    margin-bottom: 0.5rem;
  }
  .step-title {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--water-3);
    margin-bottom: 0.4rem;
    letter-spacing: 0.05em;
  }
  .step-text {
    font-size: 0.82rem;
    color: rgba(255,255,255,0.55);
    line-height: 1.7;
    font-weight: 300;
  }

  /* ─── SCREEN 3: SYNC GAME ─── */
  #game-screen {
    padding-top: 5rem;
  }
  .sync-container {
    width: 100%; max-width: 680px;
    margin: 0 auto;
  }
  .heartbeat-canvas-wrap {
    position: relative;
    width: 100%; height: 120px;
    margin-bottom: 1.5rem;
    border-radius: 12px;
    overflow: hidden;
    background: rgba(0,0,0,0.3);
    border: 1px solid rgba(255,255,255,0.06);
  }
  #heartbeat-canvas {
    width: 100%; height: 100%;
  }
  .sync-meter-wrap {
    display: flex; align-items: center; gap: 1rem;
    margin-bottom: 2rem;
  }
  .sync-label {
    font-size: 0.7rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.4);
    white-space: nowrap;
    min-width: 55px;
  }
  .sync-bar-outer {
    flex: 1; height: 6px;
    background: rgba(255,255,255,0.08);
    border-radius: 100px;
    overflow: hidden;
  }
  .sync-bar-inner {
    height: 100%; width: 0%;
    background: linear-gradient(90deg, var(--water-2), var(--fire-2));
    border-radius: 100px;
    transition: width 0.5s ease;
  }
  .sync-pct {
    font-size: 0.85rem;
    font-weight: 500;
    min-width: 36px;
    text-align: right;
    color: var(--water-3);
  }

  .tap-zones {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.2rem;
    margin-bottom: 1.5rem;
  }
  .tap-btn {
    padding: 2rem 1rem;
    border-radius: 16px;
    border: none; cursor: pointer;
    font-family: 'Outfit', sans-serif;
    font-weight: 500;
    font-size: 0.85rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    transition: transform 0.1s, box-shadow 0.2s;
    position: relative;
    overflow: hidden;
    user-select: none;
  }
  .tap-btn.fire-btn {
    background: linear-gradient(160deg, rgba(255,69,0,0.2), rgba(255,140,0,0.1));
    border: 1px solid rgba(255,140,0,0.25);
    color: var(--fire-2);
  }
  .tap-btn.water-btn {
    background: linear-gradient(160deg, rgba(0,119,182,0.2), rgba(144,224,239,0.1));
    border: 1px solid rgba(144,224,239,0.25);
    color: var(--water-3);
  }
  .tap-btn:active, .tap-btn.pressed {
    transform: scale(0.96);
  }
  .tap-btn.fire-btn.pressed {
    box-shadow: 0 0 30px rgba(255,69,0,0.5);
    background: linear-gradient(160deg, rgba(255,69,0,0.35), rgba(255,140,0,0.2));
  }
  .tap-btn.water-btn.pressed {
    box-shadow: 0 0 30px rgba(0,119,182,0.5);
    background: linear-gradient(160deg, rgba(0,119,182,0.35), rgba(144,224,239,0.2));
  }
  .tap-icon {
    font-size: 2rem;
    display: block;
    margin-bottom: 0.4rem;
  }
  .tap-hint {
    font-size: 0.7rem;
    opacity: 0.5;
    display: block;
    margin-top: 0.3rem;
    font-weight: 300;
  }

  .timer-ring {
    position: relative;
    width: 80px; height: 80px;
    margin: 0 auto 0.5rem;
  }
  .timer-ring svg { transform: rotate(-90deg); }
  .timer-ring circle.bg { fill: none; stroke: rgba(255,255,255,0.06); stroke-width: 3; }
  .timer-ring circle.prog {
    fill: none; stroke: var(--fire-2);
    stroke-width: 3; stroke-linecap: round;
    stroke-dasharray: 226; stroke-dashoffset: 226;
    transition: stroke-dashoffset 1s linear;
  }
  .timer-num {
    position: absolute; inset: 0;
    display: flex; align-items: center; justify-content: center;
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.4rem; font-weight: 300;
  }

  .pulse-dot {
    display: inline-block;
    width: 8px; height: 8px; border-radius: 50%;
    background: var(--fire-2);
    margin-right: 0.5rem;
    animation: pulse-anim 1s infinite;
  }
  @keyframes pulse-anim {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.4; transform: scale(0.6); }
  }

  /* ─── SCREEN 4: RESULT ─── */
  .mist-container {
    position: absolute; inset: 0;
    overflow: hidden; pointer-events: none;
  }
  .mist-particle {
    position: absolute;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(144,224,239,0.25), transparent);
    animation: mist-rise linear infinite;
  }
  @keyframes mist-rise {
    0% { transform: translateY(100%) scale(0); opacity: 0; }
    20% { opacity: 1; }
    100% { transform: translateY(-120vh) scale(2.5); opacity: 0; }
  }
  .result-card {
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(144,224,239,0.2);
    border-radius: 20px;
    padding: 2.5rem 2rem;
    max-width: 520px;
    width: 100%;
    position: relative;
    z-index: 2;
    backdrop-filter: blur(10px);
  }
  .result-score {
    font-family: 'Cormorant Garamond', serif;
    font-size: 5rem; font-weight: 300;
    line-height: 1;
    background: linear-gradient(135deg, var(--water-3), var(--fire-2));
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    background-clip: text;
    margin: 0.5rem 0;
  }
  .result-message {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.3rem; font-style: italic;
    color: rgba(255,255,255,0.8);
    line-height: 1.6;
    margin: 1rem 0 1.5rem;
  }
  .mist-badge {
    display: inline-flex; align-items: center; gap: 0.5rem;
    padding: 0.5rem 1.2rem;
    background: rgba(144,224,239,0.1);
    border: 1px solid rgba(144,224,239,0.25);
    border-radius: 100px;
    font-size: 0.75rem;
    color: var(--water-3);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: 1.5rem;
  }

  /* ─── SCREEN 5: REWARD ─── */
  .reward-card {
    background: linear-gradient(145deg, rgba(201,168,76,0.1), rgba(255,140,0,0.05));
    border: 1px solid rgba(201,168,76,0.3);
    border-radius: 20px;
    padding: 2.5rem;
    max-width: 480px;
    width: 100%;
    position: relative;
    overflow: hidden;
  }
  .reward-card::before {
    content: '';
    position: absolute; top: 0; left: 0; right: 0; height: 2px;
    background: linear-gradient(90deg, transparent, var(--gold), transparent);
  }
  .discount-num {
    font-family: 'Cormorant Garamond', serif;
    font-size: 6rem; font-weight: 300; line-height: 1;
    color: var(--gold);
  }
  .discount-off {
    font-family: 'Cormorant Garamond', serif;
    font-size: 2rem; font-weight: 300;
    color: rgba(201,168,76,0.7);
  }
  .coupon-code {
    margin: 1.5rem auto;
    padding: 1rem 1.5rem;
    background: rgba(0,0,0,0.3);
    border: 1px dashed rgba(201,168,76,0.4);
    border-radius: 10px;
    display: inline-block;
    cursor: pointer;
    position: relative;
  }
  .coupon-code-label {
    font-size: 0.65rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.35);
    margin-bottom: 0.3rem;
  }
  .coupon-code-value {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.8rem;
    font-weight: 400;
    letter-spacing: 0.2em;
    color: var(--gold);
  }
  .copy-hint {
    font-size: 0.65rem;
    color: rgba(255,255,255,0.3);
    margin-top: 0.3rem;
  }
  .copied-toast {
    position: absolute; top: -2rem; left: 50%; transform: translateX(-50%);
    background: rgba(0,200,100,0.9); color: #fff;
    font-size: 0.7rem; padding: 0.3rem 0.8rem;
    border-radius: 100px; white-space: nowrap;
    opacity: 0; transition: opacity 0.3s;
    pointer-events: none;
  }
  .copied-toast.show { opacity: 1; }
  .valid-text {
    font-size: 0.75rem;
    color: rgba(255,255,255,0.35);
    margin-top: 0.5rem;
  }

  /* ─── PROGRESS DOTS ─── */
  .progress-dots {
    position: fixed; bottom: 2rem; left: 50%;
    transform: translateX(-50%);
    display: flex; gap: 6px; z-index: 100;
  }
  .dot {
    width: 5px; height: 5px; border-radius: 50%;
    background: rgba(255,255,255,0.2);
    transition: all 0.3s;
  }
  .dot.active {
    width: 18px; border-radius: 3px;
    background: linear-gradient(90deg, var(--fire-2), var(--water-2));
  }

  /* ─── UTILITIES ─── */
  .mt-1 { margin-top: 0.5rem; }
  .mt-2 { margin-top: 1rem; }
  .mt-3 { margin-top: 1.5rem; }
  .flex-gap { display: flex; gap: 1rem; flex-wrap: wrap; justify-content: center; }
  .tag {
    display: inline-block; padding: 0.25rem 0.75rem;
    border-radius: 100px; font-size: 0.7rem; font-weight: 400;
    letter-spacing: 0.08em; text-transform: uppercase;
  }
  .tag-water {
    background: rgba(0,119,182,0.15);
    border: 1px solid rgba(144,224,239,0.2);
    color: var(--water-3);
  }
  .tag-fire {
    background: rgba(255,69,0,0.12);
    border: 1px solid rgba(255,140,0,0.2);
    color: var(--fire-2);
  }

  /* ─── KEYFRAME ANIMATIONS ─── */
  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(24px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .screen.active > * {
    animation: fadeInUp 0.6s ease forwards;
  }
  .screen.active > *:nth-child(2) { animation-delay: 0.1s; }
  .screen.active > *:nth-child(3) { animation-delay: 0.2s; }
  .screen.active > *:nth-child(4) { animation-delay: 0.3s; }
  .screen.active > *:nth-child(5) { animation-delay: 0.4s; }

  /* ─── CONFETTI ─── */
  .confetti-piece {
    position: fixed;
    width: 8px; height: 8px;
    border-radius: 2px;
    animation: confetti-fall linear forwards;
    z-index: 200; pointer-events: none;
  }
  @keyframes confetti-fall {
    0% { transform: translateY(-20px) rotate(0deg); opacity: 1; }
    100% { transform: translateY(100vh) rotate(720deg); opacity: 0; }
  }
</style>
</head>
<body>

<canvas id="bg-canvas"></canvas>

<div class="logo">PlayAh Her Feel</div>

<!-- Progress dots -->
<div class="progress-dots" id="progress-dots">
  <div class="dot active"></div>
  <div class="dot"></div>
  <div class="dot"></div>
  <div class="dot"></div>
  <div class="dot"></div>
</div>

<!-- ───────────────────────────────────────────────── -->
<!-- SCREEN 1: LANDING -->
<!-- ───────────────────────────────────────────────── -->
<section class="screen active" id="screen-1">
  <div class="hero-badge">An Interactive Experience</div>

  <div class="element-icons">
    <div class="fire-icon element-icon">🔥</div>
    <span class="plus-sign">+</span>
    <div class="water-icon element-icon">💧</div>
  </div>

  <p class="eyebrow">PlayAh Her Feel Presents</p>
  <h1>The <em>Intimacy</em><br><span class="fire-word">Flow</span> Station</h1>
  <div class="divider"></div>
  <p class="subtitle">
    A sensory experience where two heartbeats find their shared rhythm —
    where fire meets water and connection becomes something you can feel.
  </p>

  <div class="flex-gap">
    <span class="tag tag-fire">Fire</span>
    <span class="tag tag-water">Water</span>
    <span class="tag tag-water">Connection</span>
    <span class="tag tag-fire">Rhythm</span>
  </div>

  <div class="mt-3">
    <button class="btn-primary" onclick="goTo(2)">
      Begin the Experience &nbsp;→
    </button>
  </div>
</section>

<!-- ───────────────────────────────────────────────── -->
<!-- SCREEN 2: HOW IT WORKS -->
<!-- ───────────────────────────────────────────────── -->
<section class="screen" id="screen-2">
  <p class="eyebrow">How It Works</p>
  <h2>The <em>Heartbeat Sync</em></h2>
  <p class="subtitle">Two people. One shared pulse. Feel the invisible thread that connects you.</p>

  <div class="steps-grid">
    <div class="step-card">
      <div class="step-num">01</div>
      <div class="step-title">Feel the Pulse</div>
      <div class="step-text">Watch the heartbeat rhythm appear on screen — let it wash over you both. Breathe in sync. No rush.</div>
    </div>
    <div class="step-card">
      <div class="step-num">02</div>
      <div class="step-title">Tap Together</div>
      <div class="step-text">Each person taps their colour when they feel the beat. Fire or Water — your instincts will guide you.</div>
    </div>
    <div class="step-card">
      <div class="step-num">03</div>
      <div class="step-title">Find Your Flow</div>
      <div class="step-text">The closer your timing, the higher your sync score. 30 seconds to feel the connection.</div>
    </div>
  </div>

  <div class="flex-gap mt-2">
    <button class="btn-secondary" onclick="goTo(1)">← Back</button>
    <button class="btn-primary" onclick="startGame()">Start the Sync →</button>
  </div>
</section>

<!-- ───────────────────────────────────────────────── -->
<!-- SCREEN 3: GAME -->
<!-- ───────────────────────────────────────────────── -->
<section class="screen" id="screen-3" style="padding-top:5rem; padding-bottom:5rem;">
  <div class="sync-container">
    <div style="margin-bottom:1.2rem;">
      <p class="eyebrow"><span class="pulse-dot"></span>Live Heartbeat</p>
      <div class="timer-ring" style="margin-bottom:0.3rem;">
        <svg width="80" height="80" viewBox="0 0 80 80">
          <circle class="bg" cx="40" cy="40" r="36"/>
          <circle class="prog" id="timer-circle" cx="40" cy="40" r="36"/>
        </svg>
        <div class="timer-num" id="timer-num">30</div>
      </div>
    </div>

    <div class="heartbeat-canvas-wrap">
      <canvas id="heartbeat-canvas"></canvas>
    </div>

    <div class="sync-meter-wrap">
      <span class="sync-label">Sync</span>
      <div class="sync-bar-outer">
        <div class="sync-bar-inner" id="sync-bar"></div>
      </div>
      <span class="sync-pct" id="sync-pct">0%</span>
    </div>

    <div class="tap-zones">
      <button class="tap-btn fire-btn" id="fire-btn"
        onmousedown="registerTap('fire')" ontouchstart="registerTap('fire')">
        <span class="tap-icon">🔥</span>
        <span>Player One</span>
        <span class="tap-hint">tap in rhythm</span>
      </button>
      <button class="tap-btn water-btn" id="water-btn"
        onmousedown="registerTap('water')" ontouchstart="registerTap('water')">
        <span class="tap-icon">💧</span>
        <span>Player Two</span>
        <span class="tap-hint">tap in rhythm</span>
      </button>
    </div>

