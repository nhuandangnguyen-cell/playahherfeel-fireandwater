<script>
/* ─── NAVIGATION ─── */
let currentScreen = 1;
const TOTAL = 5;

function goTo(n) {
  document.getElementById('screen-' + currentScreen).classList.remove('active');
  document.getElementById('screen-' + n).classList.add('active');
  currentScreen = n;
  updateDots();
}

function updateDots() {
  const dots = document.querySelectorAll('.dot');
  dots.forEach((d, i) => {
    d.classList.toggle('active', i + 1 === currentScreen);
  });
}

/* ─── BACKGROUND CANVAS: FIRE & WATER PARTICLES ─── */
(function() {
  const canvas = document.getElementById('bg-canvas');
  const ctx = canvas.getContext('2d');
  let W, H, particles = [];

  function resize() {
    W = canvas.width = window.innerWidth;
    H = canvas.height = window.innerHeight;
  }
  resize();
  window.addEventListener('resize', resize);

  class Particle {
    constructor() { this.reset(); }
    reset() {
      this.x = Math.random() * W;
      this.y = H + Math.random() * 100;
      this.size = Math.random() * 3 + 1;
      this.speedY = -(Math.random() * 0.6 + 0.2);
      this.speedX = (Math.random() - 0.5) * 0.4;
      this.life = 0;
      this.maxLife = Math.random() * 200 + 100;
      const isWater = Math.random() > 0.45;
      this.isWater = isWater;
      this.hue = isWater
        ? `hsla(${200 + Math.random() * 30}, 80%, ${50 + Math.random() * 20}%,`
        : `hsla(${10 + Math.random() * 40}, 100%, ${50 + Math.random() * 20}%,`;
    }
    update() {
      this.x += this.speedX;
      this.y += this.speedY;
      this.life++;
      if (this.life > this.maxLife || this.y < -20) this.reset();
    }
    draw() {
      const a = Math.sin((this.life / this.maxLife) * Math.PI) * 0.4;
      ctx.beginPath();
      ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
      ctx.fillStyle = this.hue + a + ')';
      ctx.fill();
    }
  }

  for (let i = 0; i < 80; i++) {
    const p = new Particle();
    p.life = Math.random() * p.maxLife;
    particles.push(p);
  }

  function loop() {
    ctx.clearRect(0, 0, W, H);
    particles.forEach(p => { p.update(); p.draw(); });
    requestAnimationFrame(loop);
  }
  loop();
})();

/* ─── HEARTBEAT CANVAS ─── */
let hbCtx, hbW, hbH;
let hbOffset = 0;
let hbAnim;

function initHeartbeat() {
  const canvas = document.getElementById('heartbeat-canvas');
  hbCtx = canvas.getContext('2d');
  hbW = canvas.width = canvas.parentElement.clientWidth;
  hbH = canvas.height = canvas.parentElement.clientHeight;
}

function ecgValue(x) {
  const period = 120;
  const phase = ((x % period) + period) % period;
  if (phase < 10) return 0;
  if (phase < 15) return (phase - 10) / 5 * -0.15;
  if (phase < 20) return ((20 - phase) / 5) * -0.15;
  if (phase < 25) return 0;
  if (phase < 28) return (phase - 25) / 3 * 1;
  if (phase < 31) return ((34 - phase) / 6) * 1;
  if (phase < 34) return 0.1 + (phase - 31) / 3 * 0.2;
  if (phase < 38) return 0.3 - (phase - 34) / 4 * 0.3;
  return 0;
}

function drawHeartbeat() {
  hbCtx.clearRect(0, 0, hbW, hbH);
  hbOffset += 1.5;

  const mid = hbH / 2;
  const amp = hbH * 0.38;

  const gradient = hbCtx.createLinearGradient(0, 0, hbW, 0);
  gradient.addColorStop(0, 'rgba(144,224,239,0)');
  gradient.addColorStop(0.3, '#0077b6');
  gradient.addColorStop(0.7, '#ff8c00');
  gradient.addColorStop(1, 'rgba(255,140,0,0)');

  hbCtx.beginPath();
  for (let px = 0; px < hbW; px++) {
    const v = ecgValue(px - hbOffset);
    const py = mid - v * amp;
    px === 0 ? hbCtx.moveTo(px, py) : hbCtx.lineTo(px, py);
  }
  hbCtx.strokeStyle = gradient;
  hbCtx.lineWidth = 2;
  hbCtx.shadowColor = '#0077b6';
  hbCtx.shadowBlur = 6;
  hbCtx.stroke();
  hbCtx.shadowBlur = 0;

  // Glow dot at leading edge
  const tipV = ecgValue(hbW - hbOffset);
  const tipY = mid - tipV * amp;
  hbCtx.beginPath();
  hbCtx.arc(hbW * 0.85, tipY, 4, 0, Math.PI * 2);
  hbCtx.fillStyle = '#ff8c00';
  hbCtx.fill();

  hbAnim = requestAnimationFrame(drawHeartbeat);
}

/* ─── GAME STATE ─── */
let gameTimer, gameInterval;
let timeLeft = 30;
let fireTaps = [], waterTaps = [];
let syncScore = 0;

function startGame() {
  goTo(3);
  setTimeout(() => {
    initHeartbeat();
    drawHeartbeat();
    startTimer();
  }, 300);
}

function startTimer() {
  timeLeft = 30;
  fireTaps = []; waterTaps = [];
  syncScore = 0;
  updateSyncUI(0);

  const circle = document.getElementById('timer-circle');
  const circumference = 226;

  gameInterval = setInterval(() => {
    timeLeft--;
    document.getElementById('timer-num').textContent = timeLeft;

    const progress = (30 - timeLeft) / 30;
    circle.style.strokeDashoffset = circumference - progress * circumference;

    if (timeLeft <= 0) {
      clearInterval(gameInterval);
      cancelAnimationFrame(hbAnim);
      endGame();
    }
  }, 1000);
}

function registerTap(type) {
  const now = Date.now();
  if (type === 'fire') {
    fireTaps.push(now);
    flashBtn('fire-btn', 'pressed');
  } else {
    waterTaps.push(now);
    flashBtn('water-btn', 'pressed');
  }
  recalcSync();
}

function flashBtn(id, cls) {
  const btn = document.getElementById(id);
  btn.classList.add(cls);
  setTimeout(() => btn.classList.remove(cls), 200);
}

function recalcSync() {
  if (fireTaps.length < 2 || waterTaps.length < 2) return;

  let matchCount = 0;
  const threshold = 600;
  const recentFire = fireTaps.slice(-8);
  const recentWater = waterTaps.slice(-8);

  recentFire.forEach(ft => {
    const near = recentWater.some(wt => Math.abs(ft - wt) < threshold);
    if (near) matchCount++;
  });

  const possible = Math.max(recentFire.length, recentWater.length);
  const raw = possible > 0 ? matchCount / possible : 0;
  syncScore = Math.min(100, Math.round(raw * 120));
  updateSyncUI(syncScore);
}

function updateSyncUI(score) {
  document.getElementById('sync-bar').style.width = score + '%';
  document.getElementById('sync-pct').textContent = score + '%';
}

function endGame() {
  // Guarantee at least a resonable result to keep experience positive
  // but also allow natural variation
  const baseTaps = Math.min(fireTaps.length, waterTaps.length);
  if (baseTaps < 3) syncScore = Math.max(syncScore, 42 + Math.floor(Math.random() * 20));

  goTo(4);
  showResult(syncScore);
}

function showResult(score) {
  document.getElementById('result-score').textContent = score + '%';

  let message, sub;
  // Warm, affirming messages — never offensive, always celebrating connection
  if (score >= 75) {
    message = '"The rhythm between you is undeniable. Let PlayAh help you keep that beautiful flow alive."';
    sub = 'Your connection has a pulse all its own. That kind of sync is rare — treasure it.';
  } else if (score >= 50) {
    message = '"The rhythm is there — let PlayAh help you keep the flow alive."';
    sub = 'Your energies are finding each other. Every great connection deepens with time and intention.';
  } else {
    message = '"Every connection starts with a first spark. Let PlayAh help you fan the flame."';
    sub = 'The beginning of something is often the most thrilling part. This is just the start of your flow.';
  }

  document.getElementById('result-message').textContent = message;
  document.getElementById('result-sub').textContent = sub;

  // Always show mist badge for the experience
  const badge = document.getElementById('mist-badge');
  badge.style.display = 'inline-flex';

  spawnMist();
  spawnConfetti();
}

function spawnMist() {
  const container = document.getElementById('mist-container');
  for (let i = 0; i < 14; i++) {
    setTimeout(() => {
      const el = document.createElement('div');
      el.className = 'mist-particle';
      const size = 80 + Math.random() * 160;
      el.style.cssText = `
        width:${size}px; height:${size}px;
        left:${Math.random() * 100}%;
        bottom:0;
        animation-duration:${4 + Math.random() * 4}s;
        animation-delay:${Math.random() * 2}s;
        opacity:0;
      `;
      container.appendChild(el);
    }, i * 200);
  }
}

function spawnConfetti() {
  const colors = ['#ff4500','#ff8c00','#ffd700','#90e0ef','#0077b6','#c9a84c'];
  for (let i = 0; i < 40; i++) {
    setTimeout(() => {
      const el = document.createElement('div');
      el.className = 'confetti-piece';
      el.style.cssText = `
        left:${Math.random() * 100}vw;
        top:-10px;
        background:${colors[Math.floor(Math.random() * colors.length)]};
        animation-duration:${2 + Math.random() * 2}s;
        animation-delay:${Math.random() * 0.5}s;
        transform-origin: center;
        width:${6 + Math.random() * 6}px;
        height:${6 + Math.random() * 6}px;
      `;
      document.body.appendChild(el);
      setTimeout(() => el.remove(), 4000);
    }, i * 60);
  }
}

/* ─── COUPON COPY ─── */
function copyCode() {
  navigator.clipboard.writeText('FLOW20').catch(() => {});
  const toast = document.getElementById('copy-toast');
